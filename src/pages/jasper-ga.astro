---
import Layout from '../layouts/Layout.astro';

const seoTitle = "Shamanic Healing Near Me | Jasper GA - Heart Of A Lion Shamanism";
const seoDescription = "Shamanic healing sessions and workshops in Jasper, GA with Deanna Stennett, L.Ac., MA. Soul retrieval, energy work, learn to journey courses near you.";

const nearbyTowns = [
  "Jasper",
  "Ellijay",
  "Blue Ridge",
  "Blairsville",
  "Talking Rock",
  "Morganton",
  "Helen",
  "Gainesville"
];

const faqs = [
  {
    question: "Do you offer shamanic healing in Jasper, GA?",
    answer: "Yes! Deanna Stennett serves clients throughout Northern Georgia including Jasper. She offers both in-person sessions at her offices and can travel to clients by appointment for in-home sessions when needed."
  },
  {
    question: "What shamanic services are available near me?",
    answer: "Deanna offers individual healing sessions (soul retrieval, energy clearing, power animal connection), workshops (Learn to Journey, Wild Women Series), and special ceremonies throughout Northern Georgia."
  },
  {
    question: "How do I book a shamanic session in Jasper area?",
    answer: "Call or text Deanna at 410-961-9033 or email spiritpoint4u@gmail.com. She responds within 24 hours and can schedule sessions at her offices or arrange home visits."
  }
];

const contactInfo = {
  phone: "410-961-9033",
  email: "spiritpoint4u@gmail.com"
};
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section style="background: linear-gradient(135deg, #8B1E3F 0%, #D4AF37 100%); color: white; padding: 6rem 0;">
		<div class="container" style="text-align: center; max-width: 900px;">
			<h1 style="font-size: 3.5rem; margin-bottom: 1.5rem; color: #1A1A2E;">Shamanic Healing Near Me - Jasper, GA</h1>
			<p style="font-size: 1.5rem; margin-bottom: 2rem; opacity: 0.95;">
				Transformative shamanic healing sessions and workshops serving Jasper and surrounding Northern Georgia communities
			</p>
			<div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
				<a href="#contact" class="btn btn--secondary" style="font-size: 1.25rem; padding: 1.25rem 3rem;">Book a Session</a>
				<a href="/services" class="btn" style="background-color: white; color: #8B1E3F; font-size: 1.25rem; padding: 1.25rem 3rem;">View Services</a>
			</div>
		</div>
	</section>

	<!-- Local SEO Content -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 style="font-size: 2.5rem; margin-bottom: 2rem; color: #8B1E3F;">Shamanic Healing Services in Jasper, Georgia</h2>

			<p style="font-size: 1.25rem; line-height: 1.8; color: #5A5A5a; margin-bottom: 1.5rem;">
				Are you searching for <strong>"shamanic healing near me"</strong> in Jasper, GA? Deanna Stennett, L.Ac., MA brings over 30 years of shamanic practice to the Jasper community, offering transformative healing sessions and workshops that awaken your inner wisdom and connect you with the healing power of the spirit world.
			</p>

			<p style="font-size: 1.25rem; line-height: 1.8; color: #5A5A5a; margin-bottom: 1.5rem;">
				Jasper, nestled in the heart of North Georgia's mountain region, provides a serene and sacred setting for shamanic work that honors nature and spirit. Deanna serves clients throughout Northern Georgia, including Jasper, Ellijay, Blue Ridge, Blairsville, and surrounding communities.
			</p>

			<h3 style="color: #D4AF37; font-size: 1.75rem; margin-top: 2rem; margin-bottom: 1rem;">Why Choose Shamanic Healing in Jasper?</h3>

			<ul style="list-style: none; display: grid; gap: 1rem; margin-bottom: 2rem;">
				<li style="display: flex; align-items: start;">
					<span style="color: #D4AF37; font-size: 1.5rem; margin-right: 1rem;">🦁</span>
					<div>
						<strong style="color: #8B1E3f;">Deep Spiritual Connection:</strong> Connect with your power animal, spirit guides, and nature spirits in the peaceful mountains of Jasper.
					</div>
				</li>
				<li style="display: flex; align-items: start;">
					<span style="color: #D4AF37; font-size: 1.5rem; margin-right: 1rem;">🌲</span>
					<div>
						<strong style="color: #8B1E3f;">Nature-Based Healing:</strong> The natural beauty of Jasper's forests and mountains enhances shamanic work, creating powerful opportunities for transformation.
					</div>
				</li>
				<li style="display: flex; align-items: start;">
					<span style="color: #D4AF37; font-size: 1.5rem; margin-right: 1rem;">🎓</span>
					<div>
						<strong style="color: #8B1E3f;">Experienced Practitioner:</strong> Deanna has been practicing and teaching shamanism since 1995, with training from Sandra Ingerman, Foundation for Shamanic Studies, and Tom Cowan.
					</div>
				</li>
				<li style="display: flex; align-items: start;">
					<span style="color: #D4AF37; font-size: 1.5rem; margin-right: 1rem;">🏠</span>
					<div>
						<strong style="color: #8B1E3f;">Flexible Service Options:</strong> Sessions available at Deanna's offices in Ellijay/Blairsville or by appointment for in-home visits throughout Jasper area.
					</div>
				</li>
			</ul>

			<h3 style="color: #D4AF37; font-size: 1.75rem; margin-top: 2rem; margin-bottom: 1rem;">Services Available Near You</h3>

			<div style="display: grid; gap: 1.5rem; margin-bottom: 2rem;">
				<div style="background-color: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
					<h4 style="color: #D4AF37; font-size: 1.25rem; margin-bottom: 0.5rem;">Individual Healing Sessions</h4>
					<p style="color: #5A5A5a;">Soul retrieval, energy clearing, power animal connection - personalized shamanic healing tailored to your needs.</p>
				</div>

				<div style="background-color: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
					<h4 style="color: #D4AF37; font-size: 1.25rem; margin-bottom: 0.5rem;">Learn to Journey Workshops</h4>
					<p style="color: #5A5A5a;">Five-hour introductory workshops teaching the ancient art of shamanic journeying. Meet your power animal and discover invisible worlds.</p>
				</div>

				<div style="background-color: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
					<h4 style="color: #D4AF37; font-size: 1.25rem; margin-bottom: 0.5rem;">Special Ceremonies</h4>
					<p style="color: #5A5A5a;">New Moon, Full Moon, Solstice celebrations and rites of passage ceremonies for weddings, funerals, and life transitions.</p>
				</div>
			</div>

			<h3 style="color: #D4AF37; font-size: 1.75rem; margin-top: 2rem; margin-bottom: 1rem;">Serving Jasper and Surrounding Communities</h3>

			<p style="font-size: 1.25rem; line-height: 1.8; color: #5A5A5a; margin-bottom: 1.5rem;">
				Deanna serves clients throughout Northern Georgia, making shamanic healing accessible to residents of Jasper and nearby towns including Ellijay, Blue Ridge, Blairsville, Talking Rock, Morganton, Helen, and Gainesville.
			</p>

			<div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
				{nearbyTowns.map(town => (
					<span style="background-color: #F5EBE0; padding: 0.75rem 1.5rem; border-radius: 20px; color: #8B1E3f; font-weight: bold;">
						📍 {town}, GA
					</span>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 style="text-align: center; font-size: 2.5rem; margin-bottom: 3rem; color: #8B1E3F;">Frequently Asked Questions - Jasper Area</h2>

			<div style="display: flex; flex-direction: column; gap: 1.5rem;">
				{faqs.map(faq => (
					<div style="background-color: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
						<h3 style="color: #8B1E3F; font-size: 1.25rem; margin-bottom: 0.75rem;">{faq.question}</h3>
						<p style="color: #5A5A5a; line-height: 1.6;">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container" style="max-width: 900px; text-align: center;">
			<h2 style="font-size: 2.5rem; margin-bottom: 1rem; color: #D4AF37;">Book Your Jasper Area Session</h2>
			<p style="font-size: 1.25rem; margin-bottom: 2rem; opacity: 0.9;">
				Ready to begin your shamanic journey? Contact Deanna today to schedule your session or workshop in the Jasper area.
			</p>

			<div style="display: flex; gap: 3rem; justify-content: center; flex-wrap: wrap; margin-top: 3rem;">
				<a href={`tel:${contactInfo.phone}`} class="btn btn--secondary" style="font-size: 1.25rem; padding: 1.25rem 3rem;">📞 {contactInfo.phone}</a>
				<a href={`mailto:${contactInfo.email}`} class="btn" style="background-color: white; color: #8B1E3F; font-size: 1.25rem; padding: 1.25rem 3rem;">✉️ {contactInfo.email}</a>
			</div>

			<p style="margin-top: 2rem; opacity: 0.9;">
				In-home sessions available by appointment throughout Jasper and surrounding communities.
			</p>
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Shamanic Healing Near Me - Jasper GA",
			"description": "Shamanic healing sessions and workshops in Jasper, GA with Deanna Stennett, L.Ac., MA. Soul retrieval, energy work, learn to journey courses.",
			"url": "https://heartofalionshamanism.com/jasper-ga"
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Heart Of A Lion Shamanism - Jasper GA",
			"description": "Shamanic healing sessions and workshops serving Jasper, Georgia with Deanna Stennett, L.Ac., MA.",
			"areaServed": {
				"@type": "City",
				"name": "Jasper",
				"addressRegion": "GA"
			},
			"url": "https://heartofalionshamanism.com/jasper-ga"
		}
	</script>
</Layout>
