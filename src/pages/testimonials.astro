---
import Layout from '../layouts/Layout.astro';

const seoTitle = "Shamanic Healing Testimonials | Client Stories - Heart Of A Lion Shamanism";
const seoDescription = "Read transformative client stories and testimonials about shamanic healing sessions and workshops with Deanna Stennett, L.Ac., MA in Northern Georgia.";

const testimonials = [
  {
    text: "Deanna's shamanic work opened doors I didn't know existed. Her guidance helped me connect with my power animal and find clarity in a time of confusion.",
    author: "M.S.",
    location: "Ellijay, GA",
    service: "Individual Healing Session"
  },
  {
    text: "The Learn to Journey workshop was life-changing. Deanna creates such a safe, sacred space for transformation. I've been journeying regularly since then.",
    author: "K.M.",
    location: "Blue Ridge, GA",
    service: "Learn to Journey Workshop"
  },
  {
    text: "Working with Deanna on soul retrieval work helped me heal from trauma I thought was impossible to release. Her combination of shamanic and acupuncture knowledge is truly unique.",
    author: "J.R.",
    location: "Blairsville, GA",
    service: "Soul Retrieval Session"
  },
  {
    text: "The Wild Women series gave me a community of women who understand. Deanna's wisdom and gentle guidance helped me awaken parts of myself I'd forgotten existed.",
    author: "L.T.",
    location: "Jasper, GA",
    service: "Wild Women Series"
  },
  {
    text: "I was skeptical about shamanism at first, but Deanna's approach is so grounded and practical. The energy clearing session completely shifted my perspective on healing.",
    author: "P.W.",
    location: "Ellijay, GA",
    service: "Energy Clearing Session"
  },
  {
    text: "Deanna's solstice ceremony was one of the most powerful spiritual experiences I've ever had. 38 people gathered and felt such deep connection. She has a gift for creating sacred space.",
    author: "Anonymous",
    location: "Northern Georgia",
    service: "Solstice Celebration"
  },
  {
    text: "After years of feeling stuck, Deanna's power animal session helped me connect with my totem and understand my life purpose. I've never felt more aligned.",
    author: "S.H.",
    location: "Blue Ridge, GA",
    service: "Power Animal Connection"
  },
  {
    text: "The Messages from Nature workshop changed how I see the world forever. Now when I walk in the mountains around Ellijay, I feel like I'm having conversations with everything.",
    author: "D.K.",
    location: "Ellijay, GA",
    service: "Messages from Nature Workshop"
  }
];

const categories = [
  {
    title: "Individual Healing Sessions",
    count: 45,
    description: "Soul retrieval, energy clearing, power animal connection"
  },
  {
    title: "Workshops & Training",
    count: 200,
    description: "Learn to Journey, Wild Women Series, special ceremonies"
  },
  {
    title: "Years of Practice",
    count: 31,
    description: "Teaching shamanism since 1995"
  }
];

const contactInfo = {
  phone: "410-961-9033",
  email: "spiritpoint4u@gmail.com"
};
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero__content text-center">
			<h1 style="color: var(--color-earth-900); font-size: var(--text-5xl); margin-bottom: var(--spacing-5);">Client Stories</h1>
			<p class="lead mb-6" style="opacity: 0.95;">
				Transformative experiences from clients throughout Northern Georgia
			</p>
			<div class="hero__actions">
				<a href="/services" class="btn btn--secondary btn--lg">View Services</a>
				<a href="#contact" class="btn btn--outline btn--lg">Book a Session</a>
			</div>
		</div>
	</section>

	<!-- Stats Section -->
	<section class="section">
		<div class="container">
			<div class="grid grid--3" style="gap: var(--spacing-8);">
				{categories.map(stat => (
					<div class="stat-card">
						<h3 style="font-size: var(--text-5xl); color: var(--color-gold-500); margin-bottom: var(--spacing-2);">{stat.count}</h3>
						<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">{stat.title}</p>
						<p>{stat.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Testimonials Grid -->
	<section class="section section--light">
		<div class="container">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">What Clients Are Saying</h2>

			<div class="testimonials-grid">
				{testimonials.map(testimonial => (
					<div class="testimonial-card">
						<span style="font-size: 4rem; color: var(--color-gold-500); margin-bottom: var(--spacing-3); display: block;">"</span>
						<p class="mb-6" style="font-size: var(--text-lg); line-height: 1.8; font-style: italic;">
							{testimonial.text}
						</p>
						<div class="testimonial-footer" style="display: flex; justify-content: space-between; align-items: center; border-top: 2px solid var(--color-bg-secondary); padding-top: var(--spacing-4);">
							<div>
								<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); font-size: var(--text-base);">{testimonial.author}</p>
								<p>{testimonial.location}</p>
							</div>
							<span class="service-badge" style="background-color: var(--color-bg-secondary); padding: var(--spacing-2) var(--spacing-4); border-radius: var(--radius-full); color: var(--color-primary-800); font-size: var(--text-sm); font-weight: var(--font-semibold);">
								{testimonial.service}
							</span>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Service Area Testimonials -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Serving Northern Georgia Communities</h2>

			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{["Blue Ridge", "Ellijay", "Jasper", "Blairsville", "Talking Rock", "Morganton"].map(town => (
					<div class="community-card">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">{town}, GA</h3>
						<p>Clients from {town} and surrounding areas have experienced profound transformation through Deanna's shamanic work.</p>
					</div>
				))}
			</div>

			<div class="text-center mt-8">
				<a href="/blue-ridge-ga" class="service-area-link">Blue Ridge</a>
				<a href="/ellijay-ga" class="service-area-link">Ellijay</a>
				<a href="/jasper-ga" class="service-area-link">Jasper</a>
				<a href="/blairsville-ga" class="service-area-link">Blairsville</a>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container text-center" style="max-width: 900px;">
			<h2 class="mb-4" style="color: var(--color-gold-500); font-size: var(--text-3xl);">Create Your Own Transformation Story</h2>
			<p class="lead mb-6" style="opacity: 0.95;">
				Join hundreds of clients who have experienced profound healing and transformation through shamanic work with Deanna.
			</p>

			<div class="hero__actions" style="margin-top: var(--spacing-10);">
				<a href={`tel:${contactInfo.phone}`} class="btn btn--secondary btn--lg">📞 {contactInfo.phone}</a>
				<a href={`mailto:${contactInfo.email}`} class="btn btn--outline btn--lg">✉️ {contactInfo.email}</a>
			</div>

			<p class="mt-6" style="opacity: 0.9;">
				Deanna responds to all inquiries within 24 hours. For immediate assistance, call or text directly.
			</p>
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Shamanic Healing Testimonials - Heart Of A Lion Shamanism",
			"description": "Read transformative client stories and testimonials about shamanic healing sessions with Deanna Stennett, L.Ac., MA.",
			"url": "https://heartofalionshamanism.com/testimonials"
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Collection",
			"name": "Shamanic Healing Testimonials",
			"description": "Client testimonials and success stories from shamanic healing sessions and workshops in Northern Georgia.",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "M.S. - Soul Retrieval Success"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "K.M. - Learn to Journey Workshop"
				}
			]
		}
	</script>
</Layout>
