---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import ContactForm from '../components/ContactForm.astro';
import { site, testimonials as allTestimonials, statistics } from '../config/site.js';
import { heroConfig, getHeroStyles } from '../config/hero.js';

const seoTitle = `${site.name} | Shamanic Healing Testimonials - Client Stories`;
const seoDescription = "Read transformative client stories and testimonials about shamanic healing sessions and workshops with Deanna Stennett, L.Ac., MA in Northern Georgia.";
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section class="hero" style={getHeroStyles()}>
		<div class="hero__content text-center" style={`color: ${heroConfig.textColor};`}>
			<h1 style={`font-size: var(--text-5xl); margin-bottom: var(--spacing-5); color: ${heroConfig.textColor}; font-weight: 700;`}>Client Stories</h1>
			<p class="lead mb-6" style={`color: ${heroConfig.textColor};`}>
				Transformative experiences from clients throughout Northern Georgia
			</p>
			<div class="hero__actions">
				<a href="/services" class="btn btn--secondary btn--lg">View Services</a>
				<a href="#contact" class="btn btn--outline btn--lg">Book a Session</a>
			</div>
		</div>
	</section>

	<!-- Branding Logo Section -->
	<section class="section section--light" style="padding: var(--spacing-12) 0;">
		<div class="container text-center">
			<Logo variant="hero" />
			<p class="lead" style="max-width: 700px; margin: 0 auto;">
				Hundreds of clients throughout Northern Georgia have experienced profound healing and transformation through shamanic work with {site.tagline.split(',')[0]}.
			</p>
		</div>
	</section>

	<!-- Stats Section -->
	<section class="section">
		<div class="container">
			<div class="grid grid--3" style="gap: var(--spacing-8);">
				{statistics.map(stat => (
					<div class="stat-card">
						<h3 style="font-size: var(--text-5xl); color: var(--color-gold-500); margin-bottom: var(--spacing-2);">{stat.count}</h3>
						<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">{stat.title}</p>
						<p>{stat.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Testimonials Grid -->
	<section class="section section--light">
		<div class="container">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">What Clients Are Saying</h2>

			<div class="testimonials-grid">
				{allTestimonials.map(testimonial => (
					<div class="testimonial-card">
						<span style="font-size: 4rem; color: var(--color-gold-500); margin-bottom: var(--spacing-3); display: block;">"</span>
						<p class="mb-6" style="font-size: var(--text-lg); line-height: 1.8; font-style: italic;">
							{testimonial.text}
						</p>
						<div class="testimonial-footer" style="display: flex; justify-content: space-between; align-items: center; border-top: 2px solid var(--color-bg-secondary); padding-top: var(--spacing-4);">
							<div>
								<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); font-size: var(--text-base);">{testimonial.author}</p>
								<p>{testimonial.location}</p>
							</div>
							<span class="service-badge" style="background-color: var(--color-bg-secondary); padding: var(--spacing-2) var(--spacing-4); border-radius: var(--radius-full); color: var(--color-primary-800); font-size: var(--text-sm); font-weight: var(--font-semibold);">
								{testimonial.service}
							</span>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Service Area Testimonials -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Serving Northern Georgia Communities</h2>

			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{["Blue Ridge", "Ellijay", "Jasper", "Blairsville", "Talking Rock", "Morganton"].map(town => (
					<div class="community-card">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">{town}, GA</h3>
						<p>Clients from {town} and surrounding areas have experienced profound transformation through shamanic work.</p>
					</div>
				))}
			</div>

			<div class="text-center mt-8">
				<a href="/blue-ridge-ga" class="service-area-link">Blue Ridge</a>
				<a href="/ellijay-ga" class="service-area-link">Ellijay</a>
				<a href="/jasper-ga" class="service-area-link">Jasper</a>
				<a href="/blairsville-ga" class="service-area-link">Blairsville</a>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-4" style="color: var(--color-gold-500); font-size: var(--text-3xl);">Contact Deanna</h2>
			<p class="text-center lead mb-8">
				Ready to begin your shamanic journey? Fill out the form below or call/text directly.
			</p>

			<div class="contact-info-grid" style="margin-bottom: var(--spacing-10);">
				<div class="contact-card">
					<span class="contact-icon">📞</span>
					<h3 class="contact-title">Phone</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;">{site.phone}</p>
				</div>
				
				<div class="contact-card">
					<span class="contact-icon">✉️</span>
					<h3 class="contact-title">Email</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;"><a href={`mailto:${site.email}`} style="color: white;">{site.email}</a></p>
				</div>
				
				<div class="contact-card">
					<span class="contact-icon">📍</span>
					<h3 class="contact-title">Location</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;">{site.address}</p>
				</div>
			</div>

			<!-- Contact Form -->
			<ContactForm />
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": `${site.name} - Testimonials`,
			"description": "Read transformative client stories and testimonials about shamanic healing sessions with Deanna Stennett, L.Ac., MA.",
			"url": "https://heartofalionshamanism.com/testimonials"
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Collection",
			"name": "Shamanic Healing Testimonials",
			"description": "Client testimonials and success stories from shamanic healing sessions and workshops in Northern Georgia.",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "M.S. - Soul Retrieval Success"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "K.M. - Learn to Journey Workshop"
				}
			]
		}
	</script>
</Layout>
