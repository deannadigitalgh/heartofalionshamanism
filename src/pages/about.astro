---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import LionHeartCarousel from '../components/LionHeartCarousel.astro';
import { site, credentials, journeyTimeline, shamanicTeachers as teachers, personalStories, bookInfo, specializations } from '../config/site.js';
import { heroConfig, getHeroStyles } from '../config/hero.js';

const seoTitle = `About ${site.tagline.split(',')[0]} | Shamanic Practitioner & Teacher`;
const seoDescription = "Learn about Deanna Stennett's shamanic journey, training with Sandra Ingerman & Foundation for Shamanic Studies, and 30+ years of healing practice in Northern Georgia.";
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section class="hero" style={getHeroStyles()}>
		<div class="hero__content text-center" style={`color: ${heroConfig.textColor}; display: flex; flex-direction: column; align-items: center;`}>
			<LionHeartCarousel altText={`${site.tagline}`} />
			<h1 style={`font-size: var(--text-5xl); margin-bottom: var(--spacing-5); color: ${heroConfig.textColor}; font-weight: 700;`}>{site.tagline}</h1>
			<p class="lead mb-6" style={`color: ${heroConfig.textColor};`}>
				Shamanic Practitioner & Teacher | Licensed Acupuncturist | Author
			</p>
			<div class="hero__actions">
				<a href="#contact" class="btn btn--secondary btn--lg">Book a Session</a>
				<a href="/services" class="btn btn--outline btn--lg">View Services</a>
			</div>
		</div>
	</section>

	<!-- Bio Section -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="mb-6" style="color: var(--color-primary-800); font-size: var(--text-3xl);">About Deanna</h2>
			
			<p class="lead mb-4">
				Deanna Slate Stennett is a Georgia Licensed Acupuncturist with offices in Ellijay and Blairsville, and a shamanic practitioner dedicated to helping people awaken their inner wisdom and connect with the healing power of the spirit world.
			</p>
			
			<p class="lead mb-4">
				Deanna learned about shamanism in acupuncture school from a shaman, herbalist and acupuncturist by the name of Eliot Cowan, author of <em>Plant Spirit Medicine</em>. After acupuncture school she began studying with the Foundation for Shamanic Studies and completed their advanced 3-year program. She has also studied with Sandra Ingerman (author of many books, including <em>Soul Retrieval</em> and <em>Medicine for the Earth</em>) since 1995.
			</p>

			<p class="lead mb-4">
				Deanna has been practicing and teaching shamanism since 1995. She offers classes, workshops and healing sessions. Deanna has used shamanic journeying to meet with the spirits of the Acupuncture Points which her book <em>Poetry of the Body: Stories About Acupuncture Points</em> focuses on. It is available on Amazon and written for the lay person.
			</p>

			<p class="lead">
				Deanna Stennett is a lover of animals, nature, natural healing, art, poetry, and being a loving, compassionate healing presence on the Earth.
			</p>
		</div>
	</section>

	<!-- Credentials Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Credentials & Training</h2>
			
			<div class="grid" style="gap: var(--spacing-6);">
				{credentials.map(cred => (
					<div class="card">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">{cred.title}</h3>
						<p style="line-height: 1.6;">{cred.details}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Journey Timeline -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Deanna's Shamanic Journey</h2>
			
			<div class="timeline-container">
				<div class="timeline-line"></div>
				
				{journeyTimeline.map(point => (
					<div class="timeline-item">
						<span class="timeline-dot"></span>
						<span class="timeline-year">{point.year}</span>
						<h3 style="color: var(--color-primary-800); font-size: var(--text-xl); margin-bottom: var(--spacing-3);">{point.title}</h3>
						<p>{point.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Teachers Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Shamanic Teachers & Lineage</h2>
			
			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{teachers.map(teacher => (
					<div class="card">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-xl); margin-bottom: var(--spacing-4);">{teacher.name}</h3>
						{teacher.organization && <p style="font-weight: var(--font-semibold); color: var(--color-primary-800); margin-bottom: var(--spacing-2);">{teacher.organization}</p>}
						<p>{teacher.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Personal Stories Section -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Personal Shamanic Stories</h2>
			
			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{personalStories.map(story => (
					<div class="story-card">
						<h3 style="color: var(--color-primary-800); font-size: var(--text-xl); margin-bottom: var(--spacing-4);">{story.title}</h3>
						<p style="font-size: var(--text-lg); line-height: 1.8;">{story.story}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Book Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Author</h2>
			
			<div class="card text-center" style="padding: var(--spacing-10);">
				<h3 style="font-size: var(--text-3xl); color: var(--color-gold-500); margin-bottom: var(--spacing-2);">{bookInfo.title}</h3>
				<p style="font-style: italic; color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-6);">"{bookInfo.subtitle}"</p>
				
				<p style="line-height: 1.8; max-width: 700px; margin: 0 auto var(--spacing-8);">
					{bookInfo.description}
				</p>
				
				<div class="service-area-links" style="margin-top: var(--spacing-6);">
					{bookInfo.availableOn.map(source => (
						<span class="service-area-link">📚 Available on {source}</span>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Specializations Section -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Areas of Specialization</h2>
			
			<div class="grid grid--3" style="gap: var(--spacing-8);">
				{specializations.map(spec => (
					<div class="card card--icon">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-xl); margin-bottom: var(--spacing-4);">{spec.title}</h3>
						<p>{spec.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-4" style="color: var(--color-gold-500); font-size: var(--text-3xl);">Contact Deanna</h2>
			<p class="text-center lead mb-8">
				Ready to begin your shamanic journey? Fill out the form below or call/text directly.
			</p>

			<div class="contact-info-grid" style="margin-bottom: var(--spacing-10);">
				<div class="contact-card">
					<span class="contact-icon">📞</span>
					<h3 class="contact-title">Phone</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;">{site.phone}</p>
				</div>
				
				<div class="contact-card">
					<span class="contact-icon">✉️</span>
					<h3 class="contact-title">Email</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;"><a href={`mailto:${site.email}`} style="color: white;">{site.email}</a></p>
				</div>
				
				<div class="contact-card">
					<span class="contact-icon">📍</span>
					<h3 class="contact-title">Location</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;">{site.address}</p>
				</div>
			</div>

			<!-- Contact Form -->
			<ContactForm />
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": `About ${site.tagline.split(',')[0]} - Heart Of A Lion Shamanism`,
			"description": "Learn about Deanna Stennett's shamanic journey, training with Sandra Ingerman & Foundation for Shamanic Studies, and 30+ years of healing practice.",
			"url": "https://heartofalionshamanism.com/about"
		}
	</script>
</Layout>
