---
import Layout from '../layouts/Layout.astro';

const seoTitle = "Shamanic Workshops & Training | Deanna Stennett - Northern Georgia";
const seoDescription = "Upcoming shamanic workshops and training programs in Blue Ridge, Ellijay & Blairsville GA. Learn to journey, Wild Women series, special ceremonies.";

const upcomingWorkshops = [
  {
    title: "Learn to Journey Workshop",
    date: "April 18, 2026",
    time: "12-4 pm",
    location: "563 Gainesville Hwy., Blairsville, GA 30512",
    price: "$50 in advance, $65 at door ($2 credit card fee)",
    description: "Five-hour introductory workshop teaching the ancient art of shamanic journeying. Meet your power animal and discover the invisible worlds.",
    includes: [
      "Overview of shamanism and its history",
      "Understanding the shamanic view of illness and healing",
      "Learn to do a shamanic journey",
      "Meet your power (or totem) animal",
      "Connection with nature spirits",
      "Post-workshop food and community gathering"
    ],
    registration: "Pre-register at 410-961-9033 or spiritpoint4u@gmail.com to save $5 and ensure space",
    limit: "Limited to 20 participants for intimate experience"
  },
  {
    title: "Messages from Nature Workshop",
    date: "March 29, 2025",
    time: "12-5 pm",
    location: "284 Cozy Valley Lane, Talking Rock, GA 30175",
    price: "$60 in advance, $65 at door ($2 credit card fee)",
    description: "Explore the messages from the Creator through nature using shamanic journeying and intuition. Never look at a tree or flower the same way again.",
    includes: [
      "Shamanic journeying techniques",
      "Intuition development exercises",
      "Nature spirit communication",
      "Outdoor ceremony (weather permitting)",
      "Shared meal with other participants"
    ],
    registration: "Contact 410-961-9033 or spiritpoint4u@gmail.com to register",
    limit: "Limited space available - pre-register to save $5"
  }
];

const series = [
  {
    title: "Wild Women Series",
    description: "Six-part transformative series for women exploring wild archetypes through shamanic journeying, art, poetry, song, and dance. Based on Clarissa Pinkola Estes' work.",
    schedule: "The 2nd Saturday of each month from April through September",
    dates: ["April 8, 2023", "May 13, 2023", "June 10, 2023", "July 8, 2023", "August 12, 2023", "September 9, 2023"],
    time: "First 5 meetings: 10am-5pm (hour lunch break). 6th meeting: 1pm-9pm with potluck dinner.",
    location: "Inner Awakenings, 1650 Tate Rd., Blairsville, Georgia 30512",
    price: "$540 total ($90/session) if paid in full, or $100 per session",
    includes: [
      "Shamanic journeys to explore wild archetypes",
      "Creative expression (art, song, dance)",
      "Poetry and storytelling",
      "Ceremony and ritual work",
      "Healing friendships and support building",
      "Outdoor fire ceremony at final meeting"
    ],
    idealFor: ["Women seeking to awaken their wildness", "Connecting with intuitive self", "Building community with other women"],
    requirements: [
      "Participants must be fully committed to attending each meeting",
      "If you miss more than one meeting, you cannot continue",
      "Bring your own bag lunch for first 5 meetings",
      "Potluck dinner for final meeting"
    ],
    registration: "Call or text Deanna at 410-961-9033. Or register at Inner Awakenings with Karen Wilkins at 706-347-0528.",
    limit: "Limited to 12 women, first come first serve"
  }
];

const pastWorkshops = [
  {
    title: "Learn to Journey Course",
    date: "October 2021",
    location: "Mountain Light Unitarian Universalist Church (MLUUC), Ellijay",
    note: "First shamanic Learn to Journey course since moving to Northern Georgia. Well attended."
  },
  {
    title: "Solstice Celebration",
    date: "Summer Solstice 2021",
    location: "Mountain Light Unitarian Universalist Church (MLUUC), Ellijay",
    note: "Co-led with 38 people gathering to honor the return of the sun."
  }
];

const faqs = [
  {
    question: "What should I bring to a workshop?",
    answer: "Wear comfortable clothing that allows movement. Bring an open heart and mind. Some workshops include outdoor time, so dress appropriately for weather. A water bottle and snacks are recommended. For creative workshops, bring art supplies if you have them."
  },
  {
    question: "Do I need prior experience?",
    answer: "No! All workshops are designed for beginners. Deanna has been teaching since 1995 and creates a welcoming, accessible environment for all levels of experience."
  },
  {
    question: "What if I can't attend after registering?",
    answer: "For the Wild Women Series, participants must be fully committed. If you miss more than one meeting, you cannot continue. For single workshops, please contact Deanna as soon as possible if you need to cancel."
  },
  {
    question: "Are there dietary restrictions for shared meals?",
    answer: "Please let Deanna know of any dietary restrictions when registering. Workshops with shared meals aim to accommodate various needs."
  }
];

const contactInfo = {
  phone: "410-961-9033",
  email: "spiritpoint4u@gmail.com"
};
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero__content text-center">
			<h1 style="color: var(--color-earth-900); font-size: var(--text-5xl); margin-bottom: var(--spacing-5);">Shamanic Workshops & Training</h1>
			<p class="lead mb-6" style="opacity: 0.95;">
				Transformative group experiences in Northern Georgia with Deanna Stennett, L.Ac., MA
			</p>
			<div class="hero__actions">
				<a href="#upcoming" class="btn btn--secondary btn--lg">Upcoming Workshops</a>
				<a href="/series" class="btn btn--outline btn--lg">Series Programs</a>
			</div>
		</div>
	</section>

	<!-- Branding Logo Section -->
	<section class="section section--light" style="padding: var(--spacing-12) 0;">
		<div class="container text-center">
			<img 
				src="/logo-large.svg" 
				alt="Heart Of A Lion Shamanism - Deanna Stennett, L.Ac., MA" 
				width="300"
				height="100"
				style="margin-bottom: var(--spacing-6);"
			/>
			<p class="lead" style="max-width: 700px; margin: 0 auto;">
				Transformative group experiences designed to awaken your inner wisdom and connect you with the healing power of shamanism.
			</p>
		</div>
	</section>

	<!-- Upcoming Workshops Section -->
	<section id="upcoming" class="section">
		<div class="container">
			<h2 class="text-center mb-4" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Upcoming Workshops</h2>
			<p class="lead text-center mb-8" style="max-width: 800px; margin-left: auto; margin-right: auto;">
				Join Deanna for transformative workshops designed to awaken your inner wisdom and connect you with the healing power of shamanism.
			</p>

			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{upcomingWorkshops.map(workshop => (
					<div class="card workshop-card">
						<div class="service-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--spacing-6);">
							<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-bottom: 0;">{workshop.title}</h3>
							<div class="service-price" style="text-align: right;">
								<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); font-size: var(--text-xl);">{workshop.price}</p>
								<p style="color: var(--color-text-muted); margin-top: var(--spacing-1);">{workshop.time}</p>
							</div>
						</div>

						<div class="workshop-meta" style="display: grid; gap: var(--spacing-4); margin-bottom: var(--spacing-6);">
							<p><strong>📅 Date:</strong> {workshop.date}</p>
							<p><strong>🕐 Time:</strong> {workshop.time}</p>
							<p><strong>📍 Location:</strong> {workshop.location}</p>
						</div>

						<p class="mb-4" style="font-size: var(--text-lg); line-height: 1.8;">
							{workshop.description}
						</p>

						<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">Includes:</h4>
						<ul class="service-list" style="list-style: none; display: grid; gap: var(--spacing-2); margin-bottom: var(--spacing-6);">
							{workshop.includes.map(item => (
								<li class="service-list__item" style="display: flex; align-items: center;">
									<span class="service-list__icon" style="color: var(--color-gold-500); margin-right: var(--spacing-3);">✓</span> {item}
								</li>
							))}
						</ul>

						{workshop.limit && (
							<p class="warning-box" style="background-color: #FFF3CD; padding: var(--spacing-4); border-radius: var(--radius-md); margin-bottom: var(--spacing-6);">
								<strong>⚠️ {workshop.limit}</strong>
							</p>
						)}

						<div class="info-box" style="background-color: #E8F4FD; padding: var(--spacing-6); border-radius: var(--radius-md); margin-bottom: var(--spacing-8);">
							<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">📞 Registration</h4>
							<p style="line-height: 1.6;">{workshop.registration}</p>
						</div>

						<div class="text-center">
							<a href={`tel:${contactInfo.phone}`} class="btn btn--primary" style="padding: var(--spacing-4) var(--spacing-8); font-size: var(--text-lg);">📞 Call to Register</a>
							<p class="mt-6 text-muted">or email {contactInfo.email}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Series Programs Section -->
	<section id="series" class="section section--light">
		<div class="container">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Series Programs</h2>

			{series.map(series => (
				<div class="card series-card">
					<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-bottom: var(--spacing-4);">{series.title}</h3>

					<p class="mb-6" style="font-size: var(--text-lg); line-height: 1.8;">
						{series.description}
					</p>

					<div class="series-details" style="display: grid; gap: var(--spacing-6); margin-bottom: var(--spacing-8);">
						<p><strong>📅 Schedule:</strong> {series.schedule}</p>
						{series.dates && (
							<div class="dates-box" style="background-color: var(--color-bg-secondary); padding: var(--spacing-6); border-radius: var(--radius-md);">
								<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); margin-bottom: var(--spacing-3);">Workshop Dates:</p>
								<ul class="dates-list" style="list-style: none; display: grid; gap: var(--spacing-2);">
									{series.dates.map(date => (
										<li style="color: var(--color-text-muted);">• {date}</li>
									))}
								</ul>
							</div>
						)}

						<p><strong>🕐 Time:</strong> {series.time}</p>
						<p><strong>📍 Location:</strong> {series.location}</p>
						<p style="font-weight: var(--font-semibold); color: var(--color-gold-500); font-size: var(--text-lg);">💰 Price: {series.price}</p>
					</div>

					<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">Includes:</h4>
					<ul class="service-list" style="list-style: none; display: grid; gap: var(--spacing-2); margin-bottom: var(--spacing-6);">
						{series.includes.map(item => (
							<li class="service-list__item" style="display: flex; align-items: center;">
								<span class="service-list__icon" style="color: var(--color-gold-500); margin-right: var(--spacing-3);">✓</span> {item}
							</li>
						))}
					</ul>

					{series.idealFor && (
						<p class="info-box" style="background-color: #E8F4FD; padding: var(--spacing-4); border-radius: var(--radius-md); margin-bottom: var(--spacing-6);">
							<strong>✨ Ideal For:</strong> {series.idealFor.join(" • ")}
						</p>
					)}

					{series.requirements && (
						<div class="requirements-box" style="background-color: #FFF3CD; padding: var(--spacing-6); border-radius: var(--radius-md); margin-bottom: var(--spacing-8);">
							<h4 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">⚠️ Requirements</h4>
							<ul class="requirements-list" style="list-style: none; display: grid; gap: var(--spacing-2);">
								{series.requirements.map(req => (
									<li style="color: var(--color-text-muted);">• {req}</li>
								))}
							</ul>
						</div>
					)}

					<div class="info-box" style="background-color: #E8F4FD; padding: var(--spacing-6); border-radius: var(--radius-md); margin-bottom: var(--spacing-8);">
						<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">📞 Registration</h4>
						<p style="line-height: 1.6;">{series.registration}</p>
					</div>

					<div class="text-center">
						<a href={`tel:${contactInfo.phone}`} class="btn btn--primary" style="padding: var(--spacing-4) var(--spacing-8); font-size: var(--text-lg);">📞 Call to Register</a>
						<p class="mt-6 text-muted">or email {contactInfo.email}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- Past Workshops Section -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Recent Workshops</h2>

			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{pastWorkshops.map(workshop => (
					<div class="card past-workshop-card">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-xl); margin-bottom: var(--spacing-2);">{workshop.title}</h3>
						<p><strong>Date:</strong> {workshop.date}</p>
						<p><strong>Location:</strong> {workshop.location}</p>
						{workshop.note && <p class="mt-4" style="color: var(--color-primary-800); font-style: italic;">{workshop.note}</p>}
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Frequently Asked Questions</h2>

			<div class="faq-list">
				{faqs.map(faq => (
					<div class="faq-item">
						<h3 class="faq-question">{faq.question}</h3>
						<p class="faq-answer">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container text-center" style="max-width: 900px;">
			<h2 class="mb-4" style="color: var(--color-gold-500); font-size: var(--text-3xl);">Register for a Workshop</h2>
			<p class="lead mb-6" style="opacity: 0.95;">
				Spaces are limited for all workshops. Contact Deanna today to secure your spot.
			</p>

			<div class="hero__actions" style="margin-top: var(--spacing-10);">
				<a href={`tel:${contactInfo.phone}`} class="btn btn--secondary btn--lg">📞 {contactInfo.phone}</a>
				<a href={`mailto:${contactInfo.email}`} class="btn btn--outline btn--lg">✉️ {contactInfo.email}</a>
			</div>

			<p class="mt-6" style="opacity: 0.9;">Pre-register to save $5 on most workshops!</p>
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Shamanic Workshops & Training - Heart Of A Lion Shamanism",
			"description": "Upcoming shamanic workshops and training programs in Northern Georgia with Deanna Stennett, L.Ac., MA.",
			"url": "https://heartofalionshamanism.com/workshops"
		}
	</script>
</Layout>
