---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import { site, upcomingWorkshops as allUpcomingWorkshops, seriesPrograms, pastWorkshops, faqs } from '../config/site.js';

const seoTitle = `${site.name} | Shamanic Workshops & Training - Northern Georgia`;
const seoDescription = "Upcoming shamanic workshops and training programs in Blue Ridge, Ellijay & Blairsville GA. Learn to journey, Wild Women series, special ceremonies.";
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero__content text-center">
			<h1 style="color: var(--color-earth-900); font-size: var(--text-5xl); margin-bottom: var(--spacing-5);">Shamanic Workshops & Training</h1>
			<p class="lead mb-6" style="opacity: 0.95;">
				Transformative group experiences in Northern Georgia with {site.tagline}
			</p>
		<div class="hero__actions">
			<a href="#upcoming" class="btn btn--secondary btn--lg">Upcoming Workshops</a>
			<span class="btn btn--outline btn--lg" title="Coming Soon">Series Programs (TBD)</span>
		</div>
		</div>
	</section>

	<!-- Branding Logo Section -->
	<section class="section section--light" style="padding: var(--spacing-12) 0;">
		<div class="container text-center">
			<Logo variant="hero" />
			<p class="lead" style="max-width: 700px; margin: 0 auto;">
				Transformative group experiences designed to awaken your inner wisdom and connect you with the healing power of shamanism.
			</p>
		</div>
	</section>

	<!-- Upcoming Workshops Section -->
	<section id="upcoming" class="section">
		<div class="container">
			<h2 class="text-center mb-4" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Upcoming Workshops</h2>
			<p class="lead text-center mb-8" style="max-width: 800px; margin-left: auto; margin-right: auto;">
				Join {site.tagline.split(',')[0]} for transformative workshops designed to awaken your inner wisdom and connect you with the healing power of shamanism.
			</p>

			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{allUpcomingWorkshops.map(workshop => (
					<div class="card workshop-card">
						<div class="service-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--spacing-6);">
							<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-bottom: 0;">{workshop.title}</h3>
							<div class="service-price" style="text-align: right;">
								<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); font-size: var(--text-xl);">{workshop.price}</p>
								<p style="color: var(--color-text-muted); margin-top: var(--spacing-1);">{workshop.time}</p>
							</div>
						</div>

						<div class="workshop-meta" style="display: grid; gap: var(--spacing-4); margin-bottom: var(--spacing-6);">
							<p><strong>📅 Date:</strong> {workshop.date}</p>
							<p><strong>🕐 Time:</strong> {workshop.time}</p>
							<p><strong>📍 Location:</strong> {workshop.location}</p>
						</div>

						<p class="mb-4" style="font-size: var(--text-lg); line-height: 1.8;">
							{workshop.description}
						</p>

						<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">Includes:</h4>
						<ul class="service-list" style="list-style: none; display: grid; gap: var(--spacing-2); margin-bottom: var(--spacing-6);">
							{workshop.includes.map(item => (
								<li class="service-list__item" style="display: flex; align-items: center;">
									<span class="service-list__icon" style="color: var(--color-gold-500); margin-right: var(--spacing-3);">✓</span> {item}
								</li>
							))}
						</ul>

						{workshop.limit && (
							<p class="warning-box" style="background-color: #FFF3CD; padding: var(--spacing-4); border-radius: var(--radius-md); margin-bottom: var(--spacing-6);">
								<strong>⚠️ {workshop.limit}</strong>
							</p>
						)}

						<div class="info-box" style="background-color: #E8F4FD; padding: var(--spacing-6); border-radius: var(--radius-md); margin-bottom: var(--spacing-8);">
							<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">📞 Registration</h4>
							<p style="line-height: 1.6;">{workshop.registration}</p>
						</div>

						<div class="text-center">
							<a href={`tel:${site.phone}`} class="btn btn--primary" style="padding: var(--spacing-4) var(--spacing-8); font-size: var(--text-lg);">📞 Call to Register</a>
							<p class="mt-6 text-muted">or email {site.email}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Series Programs Section -->
	<section id="series" class="section section--light">
		<div class="container">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Series Programs</h2>

			{seriesPrograms.map(series => (
				<div class="card series-card">
					<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-bottom: var(--spacing-4);">{series.title}</h3>

					<p class="mb-6" style="font-size: var(--text-lg); line-height: 1.8;">
						{series.description}
					</p>

					<div class="series-details" style="display: grid; gap: var(--spacing-6); margin-bottom: var(--spacing-8);">
						<p><strong>📅 Schedule:</strong> {series.schedule}</p>
						{series.dates && (
							<div class="dates-box" style="background-color: var(--color-bg-secondary); padding: var(--spacing-6); border-radius: var(--radius-md);">
								<p style="font-weight: var(--font-semibold); color: var(--color-primary-800); margin-bottom: var(--spacing-3);">Workshop Dates:</p>
								<ul class="dates-list" style="list-style: none; display: grid; gap: var(--spacing-2);">
									{series.dates.map(date => (
										<li style="color: var(--color-text-muted);">• {date}</li>
									))}
								</ul>
							</div>
						)}

						<p><strong>🕐 Time:</strong> {series.time}</p>
						<p><strong>📍 Location:</strong> {series.location}</p>
						<p style="font-weight: var(--font-semibold); color: var(--color-gold-500); font-size: var(--text-lg);">💰 Price: {series.price}</p>
					</div>

					<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">Includes:</h4>
					<ul class="service-list" style="list-style: none; display: grid; gap: var(--spacing-2); margin-bottom: var(--spacing-6);">
						{series.includes.map(item => (
							<li class="service-list__item" style="display: flex; align-items: center;">
								<span class="service-list__icon" style="color: var(--color-gold-500); margin-right: var(--spacing-3);">✓</span> {item}
							</li>
						))}
					</ul>

					{series.idealFor && (
						<p class="info-box" style="background-color: #E8F4FD; padding: var(--spacing-4); border-radius: var(--radius-md); margin-bottom: var(--spacing-6);">
							<strong>✨ Ideal For:</strong> {series.idealFor.join(" • ")}
						</p>
					)}

					{series.requirements && (
						<div class="requirements-box" style="background-color: #FFF3CD; padding: var(--spacing-6); border-radius: var(--radius-md); margin-bottom: var(--spacing-8);">
							<h4 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">⚠️ Requirements</h4>
							<ul class="requirements-list" style="list-style: none; display: grid; gap: var(--spacing-2);">
								{series.requirements.map(req => (
									<li style="color: var(--color-text-muted);">• {req}</li>
								))}
							</ul>
						</div>
					)}

					<div class="info-box" style="background-color: #E8F4FD; padding: var(--spacing-6); border-radius: var(--radius-md); margin-bottom: var(--spacing-8);">
						<h4 style="color: var(--color-primary-800); font-size: var(--text-lg); margin-bottom: var(--spacing-3);">📞 Registration</h4>
						<p style="line-height: 1.6;">{series.registration}</p>
					</div>

					<div class="text-center">
						<a href={`tel:${site.phone}`} class="btn btn--primary" style="padding: var(--spacing-4) var(--spacing-8); font-size: var(--text-lg);">📞 Call to Register</a>
						<p class="mt-6 text-muted">or email {site.email}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- Past Workshops Section -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Recent Workshops</h2>

			<div class="grid grid--2" style="gap: var(--spacing-8);">
				{pastWorkshops.map(workshop => (
					<div class="card past-workshop-card">
						<h3 style="color: var(--color-gold-500); font-size: var(--text-xl); margin-bottom: var(--spacing-2);">{workshop.title}</h3>
						<p><strong>Date:</strong> {workshop.date}</p>
						<p><strong>Location:</strong> {workshop.location}</p>
						{workshop.note && <p class="mt-4" style="color: var(--color-primary-800); font-style: italic;">{workshop.note}</p>}
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Frequently Asked Questions</h2>

			<div class="faq-list">
				{faqs.general.map(faq => (
					<div class="faq-item">
						<h3 class="faq-question">{faq.question}</h3>
						<p class="faq-answer">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container text-center" style="max-width: 900px;">
			<h2 class="mb-4" style="color: var(--color-gold-500); font-size: var(--text-3xl);">Register for a Workshop</h2>
			<p class="lead mb-6" style="opacity: 0.95;">
				Spaces are limited for all workshops. Contact {site.tagline.split(',')[0]} today to secure your spot.
			</p>

			<div class="hero__actions" style="margin-top: var(--spacing-10);">
				<a href={`tel:${site.phone}`} class="btn btn--secondary btn--lg">📞 {site.phone}</a>
				<a href={`mailto:${site.email}`} class="btn btn--outline btn--lg">✉️ {site.email}</a>
			</div>

			<p class="mt-6" style="opacity: 0.9;">Pre-register to save $5 on most workshops!</p>
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": `${site.name} - Workshops`,
			"description": "Upcoming shamanic workshops and training programs in Northern Georgia with Deanna Stennett, L.Ac., MA.",
			"url": "https://heartofalionshamanism.com/workshops"
		}
	</script>
</Layout>
