---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import LionHeartCarousel from '../components/LionHeartCarousel.astro';
import { site, formspree, testimonials as allTestimonials, faqs } from '../config/site.js';
import { heroConfig, getHeroStyles } from '../config/hero.js';

const seoTitle = `${site.name} | Shamanic Healing & Workshops in Northern Georgia`;
const seoDescription = "Transformative shamanic healing sessions and workshops in Blue Ridge, Ellijay, Jasper & Blairsville GA with Deanna Stennett, L.Ac., MA. Learn shamanic journeying, energy work, and spiritual transformation.";

// Global Hero Section - Only appears on homepage
const globalHeroTitle = site.name;
const globalHeroSubtitle = "Deanna Stennett, L.Ac., MA - Shamanic Practitioner & Teacher";

// Homepage-specific services (simplified from full config)
const services = [
  {
    title: "Individual Healing Sessions",
    description: "Personalized shamanic healing tailored to your unique needs. Includes soul retrieval, energy clearing, power animal connection, and spirit guidance.",
    price: "$150-200 (60 min)",
    icon: "🌙"
  },
  {
    title: "Learn to Journey Workshops",
    description: "Four-hour introductory workshop teaching the ancient art of shamanic journeying. Meet your power animal and discover the invisible worlds.",
    price: "$50-65",
    icon: "🥁"
  },
  {
    title: "Wild Women Series",
    description: "Six-part transformative series for women exploring wild archetypes through shamanic journeying, art, poetry, song, and dance.",
    price: "$540 total ($90/session)",
    icon: "🦁"
  },
  {
    title: "Special Ceremonies",
    description: "New Moon, Full Moon, Solstice celebrations, rites of passage ceremonies including weddings and funerals.",
    price: "Varies by ceremony",
    icon: "✨"
  }
];

// Use first 2 testimonials from config for homepage preview
const homepageTestimonials = allTestimonials.slice(0, 2);

// General FAQs (first 3)
const generalFaqs = faqs.general.slice(0, 3);
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Homepage Hero with Mountain Background -->
	<section class="homepage-hero" style={getHeroStyles()} aria-hidden="true">
		<div class="global-hero__content" style={`color: ${heroConfig.textColor};`}>
			<h1 class="global-hero__title" style={`font-size: var(--text-5xl); margin-bottom: var(--spacing-5); color: ${heroConfig.textColor}; font-weight: 700;`}>{globalHeroTitle}</h1>
			<p class="global-hero__subtitle" style={`color: ${heroConfig.textColor};`}>
				{globalHeroSubtitle}
			</p>
		</div>
	<!-- Quick Action Buttons - Top Priority CTAs -->
	<div style="margin-top: var(--spacing-8); display: flex; gap: var(--spacing-4); justify-content: center; flex-wrap: wrap;">
		<a href="/workshops" class="btn btn--primary btn--lg">🥁 Upcoming Workshops</a>
		<a href="/services#individual" class="btn btn--secondary btn--lg">💫 Individual Healing Sessions</a>
	</div>
	</section>

	<!-- About Section -->
	<section class="section section--light">
		<div class="container text-center" style="max-width: 1000px; display: flex; flex-direction: column; align-items: center;">
			<LionHeartCarousel altText="Deanna Stennett - Shamanic Practitioner & Teacher" />
			<h2 class="mb-6">Welcome to Heart Of A Lion Shamanism</h2>
			<p class="lead mb-6">
				Shamanism is a spiritual practice that is not religiously affiliated with any one belief system. It is the oldest known spiritual healing system on the planet, dating back 40-100 thousand years based on archaeological studies.
			</p>
			<p class="lead">
				Deanna Stennett has been practicing and teaching shamanism since 1995, offering classes, workshops, and healing sessions throughout the Eastern US. Now in Northern Georgia, she continues her sacred work helping people awaken to a world on a different dimension where they can find anything they want and learn how to live in harmony with the world, themselves, and others.
			</p>
		</div>
	</section>

	<!-- Services Section -->
	<section class="section">
		<div class="container">
			<h2 class="text-center mb-8">Shamanic Offerings</h2>
			
			<div class="grid grid--3" style="margin-bottom: var(--spacing-10);">
				{services.map(service => (
					<div class="card card--icon">
						<span class="card__icon">{service.icon}</span>
						<h3 class="card__title">{service.title}</h3>
						<p class="card__description">{service.description}</p>
						<p style="font-weight: var(--font-semibold); color: var(--color-gold-500); margin-top: var(--spacing-2);">{service.price}</p>
					</div>
				))}
			</div>

			<!-- CTA -->
			<div class="featured">
				<h3 style="font-size: var(--text-3xl); margin-bottom: var(--spacing-4); color: var(--color-gold-500);">Ready to Begin Your Journey?</h3>
				<p class="featured__subtitle" style="margin-bottom: var(--spacing-6);">Contact Deanna today to schedule your first session or workshop</p>
				<a href="#contact" class="btn btn--primary btn--lg">Get in Touch</a>
			</div>
		</div>
	</section>

	<!-- Testimonials Section -->
	<section class="section section--light">
		<div class="container">
			<h2 class="text-center mb-8">Client Stories</h2>
			
			<div class="testimonials-grid">
				{homepageTestimonials.map(testimonial => (
					<div class="testimonial-card">
						<p class="testimonial-card__quote">"{testimonial.text}"</p>
						<p class="testimonial-card__author">— {testimonial.author}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8">Frequently Asked Questions</h2>
			
			<div class="faq-list">
				{generalFaqs.map(faq => (
					<div class="faq-item">
						<h3 class="faq-question">{faq.question}</h3>
						<p class="faq-answer">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-4" style="color: var(--color-gold-500);">Contact Deanna</h2>
			<p class="text-center lead mb-8">
				Ready to begin your shamanic journey? Fill out the form below or call/text directly.
			</p>

			<div class="contact-info-grid" style="margin-bottom: var(--spacing-10);">
				<div class="contact-card">
					<span class="contact-icon">📞</span>
					<h3 class="contact-title">Phone</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;">{site.phone}</p>
				</div>
				
				<div class="contact-card">
					<span class="contact-icon">✉️</span>
					<h3 class="contact-title">Email</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;"><a href={`mailto:${site.email}`} style="color: white;">{site.email}</a></p>
				</div>
				
				<div class="contact-card">
					<span class="contact-icon">📍</span>
					<h3 class="contact-title">Location</h3>
					<p style="font-size: var(--text-lg); opacity: 0.9;">{site.address}</p>
				</div>
			</div>

			<!-- Contact Form -->
			<ContactForm />
		</div>
	</section>

	<!-- Service Area SEO Section -->
	<section class="section section--light">
		<div class="container text-center">
			<h2 style="font-size: var(--text-3xl); margin-bottom: var(--spacing-6);">Serving Northern Georgia</h2>
			<p style="font-size: var(--text-lg); color: var(--color-text-muted); max-width: 800px; margin: 0 auto var(--spacing-8);">
				Heart Of A Lion Shamanism serves clients throughout Northern Georgia, including Blue Ridge, Ellijay, Jasper, Blairsville, and surrounding communities. Deanna travels to clients by appointment for in-home sessions when needed.
			</p>
			
			<div class="service-area-links">
				<a href="/blue-ridge-ga" class="service-area-link">Blue Ridge, GA</a>
				<a href="/ellijay-ga" class="service-area-link">Ellijay, GA</a>
				<a href="/jasper-ga" class="service-area-link">Jasper, GA</a>
				<a href="/blairsville-ga" class="service-area-link">Blairsville, GA</a>
			</div>
		</div>
	</section>

	<!-- Book Now CTA -->
	<section class="container" style="text-align: center; background-color: var(--color-primary-800); color: white; padding: var(--spacing-16) var(--spacing-6); border-radius: var(--radius-xl); margin: var(--spacing-20) 0;">
		<h2 style="font-size: var(--text-4xl); margin-bottom: var(--spacing-4); color: var(--color-gold-500);">Begin Your Transformation Today</h2>
		<p class="featured__subtitle" style="margin-bottom: var(--spacing-6);">
			Shamanic healing can bring profound change to your life. Take the first step toward transformation.
		</p>
		<div class="hero__actions">
			<a href="#contact" class="btn btn--secondary btn--lg">Book a Session Now</a>
			<a href={`tel:${site.phone}`} class="btn btn--outline btn--lg">Call {site.phone}</a>
		</div>
	</section>

	<!-- Schema Markup for Homepage -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": `${site.name} - Home`,
			"description": "Shamanic healing sessions and workshops in Northern Georgia with Deanna Stennett, L.Ac., MA. Learn shamanic journeying, energy work, and spiritual transformation.",
			"url": "https://heartofalionshamanism.com"
		}
	</script>
</Layout>
