---
import Layout from '../layouts/Layout.astro';

const seoTitle = "Shamanic Healing Near Me | Blue Ridge GA - Heart Of A Lion Shamanism";
const seoDescription = "Shamanic healing sessions and workshops in Blue Ridge, GA with Deanna Stennett, L.Ac., MA. Soul retrieval, energy work, learn to journey courses near you.";

const nearbyTowns = [
  "Blue Ridge",
  "Ellijay",
  "Jasper",
  "Blairsville",
  "Talking Rock",
  "Morganton",
  "Helen",
  "Gainesville"
];

const faqs = [
  {
    question: "Do you offer shamanic healing in Blue Ridge, GA?",
    answer: "Yes! Deanna Stennett serves clients throughout Northern Georgia including Blue Ridge. She offers both in-person sessions at her Ellijay/Blairsville offices and can travel to clients by appointment for in-home sessions when needed."
  },
  {
    question: "What shamanic services are available near me?",
    answer: "Deanna offers individual healing sessions (soul retrieval, energy clearing, power animal connection), workshops (Learn to Journey, Wild Women Series), and special ceremonies throughout Northern Georgia."
  },
  {
    question: "How do I book a shamanic session in Blue Ridge area?",
    answer: "Call or text Deanna at 410-961-9033 or email spiritpoint4u@gmail.com. She responds within 24 hours and can schedule sessions at her offices or arrange home visits."
  }
];

const contactInfo = {
  phone: "410-961-9033",
  email: "spiritpoint4u@gmail.com"
};
---

<Layout title={seoTitle} seoDescription={seoDescription}>
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero__content text-center">
			<h1 style="color: var(--color-earth-900); font-size: var(--text-5xl); margin-bottom: var(--spacing-5);">Shamanic Healing Near Me - Blue Ridge, GA</h1>
			<p class="lead mb-6" style="opacity: 0.95;">
				Transformative shamanic healing sessions and workshops serving Blue Ridge and surrounding Northern Georgia communities
			</p>
			<div class="hero__actions">
				<a href="#contact" class="btn btn--secondary btn--lg">Book a Session</a>
				<a href="/services" class="btn btn--outline btn--lg">View Services</a>
			</div>
		</div>
	</section>

	<!-- Branding Logo Section -->
	<section class="section section--light" style="padding: var(--spacing-12) 0;">
		<div class="container text-center">
			<img 
				src="/logo-large.svg" 
				alt="Heart Of A Lion Shamanism - Deanna Stennett, L.Ac., MA" 
				width="300"
				height="100"
				style="margin-bottom: var(--spacing-6);"
			/>
			<p class="lead" style="max-width: 700px; margin: 0 auto;">
				Serving Blue Ridge and surrounding Northern Georgia communities with authentic shamanic healing, workshops, and training programs.
			</p>
		</div>
	</section>

	<!-- Local SEO Content -->
	<section class="section">
		<div class="container" style="max-width: 900px;">
			<h2 class="mb-6" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Shamanic Healing Services in Blue Ridge, Georgia</h2>

			<p class="lead mb-4">
				Are you searching for <strong>"shamanic healing near me"</strong> in Blue Ridge, GA? Deanna Stennett, L.Ac., MA brings over 30 years of shamanic practice to the Blue Ridge community, offering transformative healing sessions and workshops that awaken your inner wisdom and connect you with the healing power of the spirit world.
			</p>

			<p class="lead mb-4">
				Located in the beautiful southern Appalachian mountains, Blue Ridge provides a perfect setting for shamanic work that honors nature and spirit. Deanna serves clients throughout Northern Georgia, including Blue Ridge, Ellijay, Jasper, Blairsville, and surrounding communities.
			</p>

			<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-top: var(--spacing-8); margin-bottom: var(--spacing-4);">Why Choose Shamanic Healing in Blue Ridge?</h3>

			<ul class="local-list" style="list-style: none; display: grid; gap: var(--spacing-4); margin-bottom: var(--spacing-8);">
				<li class="local-list__item" style="display: flex; align-items: start;">
					<span class="local-list__icon" style="color: var(--color-gold-500); font-size: var(--text-xl); margin-right: var(--spacing-3);">🦁</span>
					<div>
						<strong style="color: var(--color-primary-800);">Deep Spiritual Connection:</strong> Connect with your power animal, spirit guides, and nature spirits in the sacred mountains of Blue Ridge.
					</div>
				</li>
				<li class="local-list__item" style="display: flex; align-items: start;">
					<span class="local-list__icon" style="color: var(--color-gold-500); font-size: var(--text-xl); margin-right: var(--spacing-3);">🌿</span>
					<div>
						<strong style="color: var(--color-primary-800);">Nature-Based Healing:</strong> The natural beauty of Blue Ridge enhances shamanic work, creating powerful opportunities for transformation and healing.
					</div>
				</li>
				<li class="local-list__item" style="display: flex; align-items: start;">
					<span class="local-list__icon" style="color: var(--color-gold-500); font-size: var(--text-xl); margin-right: var(--spacing-3);">🎓</span>
					<div>
						<strong style="color: var(--color-primary-800);">Experienced Practitioner:</strong> Deanna has been practicing and teaching shamanism since 1995, with training from Sandra Ingerman, Foundation for Shamanic Studies, and Tom Cowan.
					</div>
				</li>
				<li class="local-list__item" style="display: flex; align-items: start;">
					<span class="local-list__icon" style="color: var(--color-gold-500); font-size: var(--text-xl); margin-right: var(--spacing-3);">🏠</span>
					<div>
						<strong style="color: var(--color-primary-800);">Flexible Service Options:</strong> Sessions available at Deanna's offices in Ellijay/Blairsville or by appointment for in-home visits throughout Blue Ridge area.
					</div>
				</li>
			</ul>

			<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-top: var(--spacing-8); margin-bottom: var(--spacing-4);">Services Available Near You</h3>

			<div class="grid grid--3" style="gap: var(--spacing-6); margin-bottom: var(--spacing-8);">
				<div class="card service-card">
					<h4 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">Individual Healing Sessions</h4>
					<p>Soul retrieval, energy clearing, power animal connection - personalized shamanic healing tailored to your needs.</p>
				</div>

				<div class="card service-card">
					<h4 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">Learn to Journey Workshops</h4>
					<p>Five-hour introductory workshops teaching the ancient art of shamanic journeying. Meet your power animal and discover invisible worlds.</p>
				</div>

				<div class="card service-card">
					<h4 style="color: var(--color-gold-500); font-size: var(--text-lg); margin-bottom: var(--spacing-2);">Special Ceremonies</h4>
					<p>New Moon, Full Moon, Solstice celebrations and rites of passage ceremonies for weddings, funerals, and life transitions.</p>
				</div>
			</div>

			<h3 style="color: var(--color-gold-500); font-size: var(--text-2xl); margin-top: var(--spacing-8); margin-bottom: var(--spacing-4);">Serving Blue Ridge and Surrounding Communities</h3>

			<p class="mb-6">
				Deanna serves clients throughout Northern Georgia, making shamanic healing accessible to residents of Blue Ridge and nearby towns including Ellijay, Jasper, Blairsville, Talking Rock, Morganton, Helen, and Gainesville.
			</p>

			<div class="service-area-links" style="margin-top: var(--spacing-6);">
				{nearbyTowns.map(town => (
					<span class="service-area-link">📍 {town}, GA</span>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="section section--light">
		<div class="container" style="max-width: 900px;">
			<h2 class="text-center mb-8" style="color: var(--color-primary-800); font-size: var(--text-3xl);">Frequently Asked Questions - Blue Ridge Area</h2>

			<div class="faq-list">
				{faqs.map(faq => (
					<div class="faq-item">
						<h3 class="faq-question">{faq.question}</h3>
						<p class="faq-answer">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="section section--dark">
		<div class="container text-center" style="max-width: 900px;">
			<h2 class="mb-4" style="color: var(--color-gold-500); font-size: var(--text-3xl);">Book Your Blue Ridge Area Session</h2>
			<p class="lead mb-6" style="opacity: 0.95;">
				Ready to begin your shamanic journey? Contact Deanna today to schedule your session or workshop in the Blue Ridge area.
			</p>

			<div class="hero__actions" style="margin-top: var(--spacing-10);">
				<a href={`tel:${contactInfo.phone}`} class="btn btn--secondary btn--lg">📞 {contactInfo.phone}</a>
				<a href={`mailto:${contactInfo.email}`} class="btn btn--outline btn--lg">✉️ {contactInfo.email}</a>
			</div>

			<p class="mt-6" style="opacity: 0.9;">
				In-home sessions available by appointment throughout Blue Ridge and surrounding communities.
			</p>
		</div>
	</section>

	<!-- Schema Markup -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Shamanic Healing Near Me - Blue Ridge GA",
			"description": "Shamanic healing sessions and workshops in Blue Ridge, GA with Deanna Stennett, L.Ac., MA. Soul retrieval, energy work, learn to journey courses.",
			"url": "https://heartofalionshamanism.com/blue-ridge-ga"
		}
	</script>

	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Heart Of A Lion Shamanism - Blue Ridge GA",
			"description": "Shamanic healing sessions and workshops serving Blue Ridge, Georgia with Deanna Stennett, L.Ac., MA.",
			"areaServed": {
				"@type": "City",
				"name": "Blue Ridge",
				"addressRegion": "GA"
			},
			"url": "https://heartofalionshamanism.com/blue-ridge-ga"
		}
	</script>
</Layout>
