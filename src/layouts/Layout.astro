---
// Import global stylesheet for all pages using this layout
import '../styles/global.css';
import Logo from '../components/Logo.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<!-- Favicon - Multiple sizes for better compatibility -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" sizes="180x180" href="/icon256.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/icon64.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{Astro.frontmatter?.title ?? "Heart Of A Lion Shamanism | Deanna Stennett, L.Ac., MA"}</title>
		<meta name="title" content={Astro.frontmatter?.seoTitle ?? "Heart Of A Lion Shamanism | Deanna Stennett, L.Ac., MA"} />
		<meta name="description" content={Astro.frontmatter?.seoDescription ?? "Shamanic healing sessions and workshops in Northern Georgia with Deanna Stennett, L.Ac., MA. Learn shamanic journeying, energy work, and spiritual transformation."} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={Astro.frontmatter?.seoTitle ?? "Heart Of A Lion Shamanism | Deanna Stennett, L.Ac., MA"} />
		<meta property="og:description" content={Astro.frontmatter?.seoDescription ?? "Shamanic healing sessions and workshops in Northern Georgia with Deanna Stennett, L.Ac., MA."} />
		<meta property="og:image" content="/heart-of-lion-og.jpg" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={Astro.frontmatter?.seoTitle ?? "Heart Of A Lion Shamanism | Deanna Stennett, L.Ac., MA"} />
		<meta property="twitter:description" content={Astro.frontmatter?.seoDescription ?? "Shamanic healing sessions and workshops in Northern Georgia with Deanna Stennett, L.Ac., MA."} />
		<meta property="twitter:image" content="/heart-of-lion-og.jpg" />

		<!-- Schema Markup -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "LocalBusiness",
				"name": "Heart Of A Lion Shamanism",
				"alternateName": "Deanna Stennett, L.Ac., MA - Shamanic Practitioner",
				"description": "Shamanic healing sessions and workshops in Northern Georgia. Deanna Stennett offers shamanic journeying, energy work, soul retrieval, and transformative ceremonies.",
				"url": "https://heartofalionshamanism.com",
				"telephone": "+1-410-961-9033",
				"email": "spiritpoint4u@gmail.com",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "Blue Ridge, GA",
					"addressLocality": "Blue Ridge",
					"addressRegion": "GA",
					"postalCode": "30175",
					"addressCountry": "US"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": 34.8296,
					"longitude": -84.5531
				},
				"areaServed": [
					{
						"@type": "City",
						"name": "Blue Ridge",
						"addressRegion": "GA"
					},
					{
						"@type": "City",
						"name": "Ellijay",
						"addressRegion": "GA"
					},
					{
						"@type": "City",
						"name": "Jasper",
						"addressRegion": "GA"
					},
					{
						"@type": "City",
						"name": "Blairsville",
						"addressRegion": "GA"
					}
				],
				"priceRange": "$$",
				"openingHoursSpecification": [
					{
						"@type": "OpeningHoursSpecification",
						"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
						"opens": "09:00",
						"closes": "17:00"
					}
				],
				"sameAs": [
					"https://www.facebook.com/",
					"https://www.instagram.com/"
				]
			}
		</script>

		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Deanna Stennett",
				"alternateName": "AA, Deanna Slate Stennett",
				"description": "Georgia Licensed Acupuncturist (L.Ac., MA), Nationally Certified with NCCAOM. Shamanic practitioner trained by Foundation for Shamanic Studies, Sandra Ingerman, and Tom Cowan.",
				"url": "https://heartofalionshamanism.com",
				"jobTitle": "Shamanic Practitioner & Teacher",
				"worksFor": {
					"@type": "Organization",
					"name": "Heart Of A Lion Shamanism"
				},
				"knowsAbout": [
					"Shamanic Healing",
					"Soul Retrieval",
					"Energy Work",
					"Shamanic Journeying",
					"Medicine Wheel Ceremonies",
					"Spirit Animal Communication",
	 	 "Acupuncture",
		 	 "NAET Allergy Elimination Technique"
		 	 ],
				"hasOccupation": {
					"@type": "Occupation",
					"name": "Licensed Acupuncturist",
					"occupationLocation": {
						"@type": "StateProvince",
						"name": "Georgia"
					},
					"skills": ["Five Element Acupuncture", "NAET", "Pain Relief", "Immune System Support"]
				}
			}
		</script>
	</head>
	<body>
		<!-- Skip Link for Accessibility -->
		<a href="#main-content" class="skip-link">Skip to main content</a>

		<!-- Navigation -->
		<nav class="navbar" aria-label="Main navigation">
			<div class="navbar__container">
				<a href="/" class="navbar__logo" aria-label="Heart Of A Lion Shamanism Home">
					<Logo variant="navbar" />
					<span class="navbar__logo-text">Heart Of A Lion Shamanism</span>
				</a>
				
				<button class="navbar__toggle" aria-expanded="false" aria-controls="navbar-menu" aria-label="Toggle navigation menu">
					<span class="navbar__hamburger"></span>
				</button>
				
				<ul id="navbar-menu" class="navbar__nav">
					<li><a href="/about" class="navbar__link">About Dee</a></li>
					<li><a href="/services" class="navbar__link">Services</a></li>
					<li><a href="/workshops" class="navbar__link">Workshops</a></li>
					<li><a href="/testimonials" class="navbar__link">Testimonials</a></li>
					<li><a href="#contact" class="navbar__link navbar__link--highlight">Contact</a></li>
				</ul>
			</div>
		</nav>

	<!-- Global Hero Background (removed from layout to prevent duplication) -->
	
	<!-- Main Content -->
	<main id="main-content">
		<slot />
	</main>

		<!-- Mobile CTA Bar -->
		<div class="mobile-cta-bar" role="navigation" aria-label="Mobile actions">
			<a href="tel:4109619033" class="mobile-cta-bar__link mobile-cta-bar__link--call">
				<span class="mobile-cta-bar__icon">📞</span>
				<span>Call Now</span>
			</a>
			<a href="#contact" class="mobile-cta-bar__link mobile-cta-bar__link--book">
				<span class="mobile-cta-bar__icon">📅</span>
				<span>Book Session</span>
			</a>
		</div>

		<!-- Footer -->
		<footer class="site-footer" aria-label="Site footer">
			<div class="container">
				<div class="footer-grid">
			<div class="footer-section">
				<img src="/AA-headshot-dee.jpg" alt="" width="80" height="80" class="headshot-circle footer-headshot" style="margin-bottom: var(--spacing-3);" />
					<h3 class="footer-title">Heart Of A Lion Shamanism</h3>
					<p class="footer-text">Deanna Stennett, L.Ac., MA<br />
					Nationally Certified NCCAOM<br />
					Shamanic Practitioner & Teacher</p>
				</div>
					
					<div class="footer-section">
						<h3 class="footer-title">Services</h3>
						<ul class="footer-list">
							<li><a href="/services#individual" class="footer-link">Individual Healing Sessions</a></li>
							<li><a href="/services#workshops" class="footer-link">Group Workshops</a></li>
							<li><a href="/services#journey" class="footer-link">Learn to Journey Training</a></li>
							<li><a href="/services#ceremonies" class="footer-link">Special Ceremonies</a></li>
						</ul>
					</div>
					
					<div class="footer-section">
						<h3 class="footer-title">Service Areas</h3>
						<ul class="footer-list">
							<li><a href="/blue-ridge-ga" class="footer-link">Blue Ridge, GA</a></li>
							<li><a href="/ellijay-ga" class="footer-link">Ellijay, GA</a></li>
							<li><a href="/jasper-ga" class="footer-link">Jasper, GA</a></li>
							<li><a href="/blairsville-ga" class="footer-link">Blairsville, GA</a></li>
						</ul>
					</div>
					
					<div id="contact" class="footer-section">
						<h3 class="footer-title">Contact</h3>
						<p class="footer-text">📞 410-961-9033<br />
						✉️ spiritpoint4u@gmail.com<br />
						📍 Blue Ridge, GA</p>
					</div>
				</div>
				
				<div class="footer-bottom">
					<p>&copy; {new Date().getFullYear()} Heart Of A Lion Shamanism. All rights reserved.</p>
				</div>
			</div>
		</footer>

		<script>
			// Mobile navigation toggle
			const navbarToggle = document.querySelector('.navbar__toggle');
			const navbarMenu = document.getElementById('navbar-menu');
			
			if (navbarToggle && navbarMenu) {
				navbarToggle.addEventListener('click', () => {
					const isExpanded = navbarToggle.getAttribute('aria-expanded') === 'true';
					navbarToggle.setAttribute('aria-expanded', !isExpanded);
					navbarMenu.classList.toggle('navbar__nav--active');
				});
			}
		</script>
	</body>
</html>
