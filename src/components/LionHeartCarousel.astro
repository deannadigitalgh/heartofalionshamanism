---
// LionHeartCarousel - Rotating headshot gallery with rounded frame styling
interface Props {
  altText?: string;
}

const { 
  // Customize this for shamanism branding if desired
  altText = "Deanna Stennett" 
} = Astro.props;

// List of all headshot filenames - UPDATE THIS with your actual image names!
const headshots = [
  '/headshots/AA-headshot-1.jpeg',
  '/headshots/AA-headshot-2.jpeg',
  '/headshots/AA-headshot-3.jpeg',
  '/headshots/AA-headshot-4.jpeg',
  '/headshots/AA-headshot-5.jpeg',
  '/headshots/AA-headshot-6.jpeg',
  '/headshots/AA-headshot-7.jpeg',
  '/headshots/AA-headshot-8.jpeg',
  '/headshots/AA-headshot-9.jpeg',
  '/headshots/AA-headshot-10.jpg'
];

// Optional: Randomize starting image on page load for variety
const startIndex = Math.floor(Math.random() * headshots.length);
---

<div class="headshot-carousel" data-start-index={startIndex}>
  {headshots.map((src, index) => (
    <img 
      src={src} 
      alt={`${altText} - Photo ${index + 1}`}
      class={`headshot-image${startIndex === index ? ' active' : ''}`} // Set first image as initially visible
    />
  ))}
</div>

<script>
const carousel = document.querySelector('.headshot-carousel');
if (carousel) {
  const images = Array.from(carousel.querySelectorAll('.headshot-image'));
  
  if (images.length > 0) {
    // Get startIndex from data attribute
    const startIndex = parseInt(carousel.getAttribute('data-start-index'), 10);
    let currentIndex = isNaN(startIndex) ? 0 : startIndex;
    
    function showImage(index) {
      images.forEach((img, i) => {
        img.classList.toggle('active', i === index);
      });
      carousel.setAttribute('data-current-image', String(currentIndex + 1));
    }

    // Ensure first image is active on load
    showImage(currentIndex);
    
    // Cycle through images every 3 seconds (customize if desired)
    setInterval(() => { 
      currentIndex = (currentIndex + 1) % images.length; 
      showImage(currentIndex); 
    }, 3000);
  }
}
</script>
<style is:global>
/* Headshot Carousel - Circular Gold Frame Styling */
.headshot-carousel {
  position: relative;
  width: 250px !important;
  height: 250px !important;
  margin-left: auto !important;
  margin-right: auto !important;
}

@media (max-width: 768px) {
  .headshot-carousel {
    width: 180px !important;
    height: 180px !important;
  }
}

.headshot-image {
  position: absolute !important;
  top: 2px; /* Account for border */
  left: 2px; /* Account for border */
  width: calc(100% - 4px) !important; /* Account for border */
  height: calc(100% - 4px) !important;
  border-radius: 50%;
  border: 4px solid var(--color-gold-500);
  box-shadow: 0 8px 24px rgba(61, 43, 31, 0.12);
  opacity: 0;
  transition: opacity 1s ease-in-out;
  object-fit: cover;
  z-index: 1;
}

.headshot-image.active {
  opacity: 1 !important;
  z-index: 999;
}

@media (hover: hover) and (min-width: 769px) {
  .headshot-carousel:hover .headshot-image:not(.active) {
    transform: scale(0.98);
  }
}

.headshot-carousel:focus-within {
  outline: none;
}
</style>
