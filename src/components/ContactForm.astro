---
import { formspree, serviceTypeOptions } from '../config/site.js';

interface Props {
  title?: string;
  showServiceDropdown?: boolean;
  buttonText?: string;
}

const { 
  title = "Send Deanna a Message", 
  showServiceDropdown = false,
  buttonText = "Send Message"
} = Astro.props;
---

<div class="contact-form-container">
	<form action={formspree.endpoint} method="POST">
		<div class="grid grid--2" style="gap: var(--spacing-5); margin-bottom: var(--spacing-5);">
			<div class="form-group">
				<label for="firstName" class="form-label">First Name *</label>
				<input type="text" id="firstName" name="first_name" required class="form-input" placeholder="Your first name" />
			</div>
			
			<div class="form-group">
				<label for="lastName" class="form-label">Last Name *</label>
				<input type="text" id="lastName" name="last_name" required class="form-input" placeholder="Your last name" />
			</div>
		</div>
		
		<div class="form-group">
			<label for="email" class="form-label">Email Address *</label>
			<input type="email" id="email" name="email" required class="form-input" placeholder="your@email.com" />
		</div>
		
		<div class="form-group">
			<label for="phone" class="form-label">Phone Number *</label>
			<input type="tel" id="phone" name="phone" required class="form-input" placeholder="(123) 456-7890" />
		</div>
		
		{showServiceDropdown && (
			<div class="form-group">
				<label for="serviceType" class="form-label">Interested In *</label>
				<select id="serviceType" name="service_type" required class="form-input">
					<option value="">Select a service...</option>
					{serviceTypeOptions.map(option => (
						<option value={option.value}>{option.label}</option>
					))}
				</select>
			</div>
		)}
		
		<div class="form-group">
			<label for="message" class="form-label">How Can I Help You? *</label>
			<textarea id="message" name="message" rows="4" required class="form-textarea" placeholder="Tell me about what brings you to shamanic healing..."></textarea>
		</div>
		
		<button type="submit" class="btn btn--primary" style="width: 100%;">{buttonText}</button>
	</form>

	<p class="text-center mt-6 text-muted" style="font-size: var(--text-sm);">
		Deanna will respond to your message within 24 hours. For immediate assistance, please call or text directly.
	</p>
</div>
