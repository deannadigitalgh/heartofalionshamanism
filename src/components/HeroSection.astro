---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
}

const { 
  title, 
  subtitle = "Deanna Stennett, L.Ac., MA - Shamanic Practitioner & Teacher",
  backgroundImage = '/bg/BlueRidgeMountainsBackground1.jpg'
} = Astro.props;
---

<section class="hero" style="background-image: linear-gradient(135deg, rgba(26, 26, 46, 0.7) 0%, rgba(139, 30, 63, 0.65) 100%), url('${backgroundImage}');">
	<div class="hero__content text-center">
		<h1 style="color: var(--color-earth-900); font-size: var(--text-5xl); margin-bottom: var(--spacing-5);">{title}</h1>
		{subtitle && <p class="lead mb-6" style="opacity: 0.95;">{subtitle}</p>}
	</div>
</section>
